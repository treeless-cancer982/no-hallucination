{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/edit-timestamp.sh"
          }
        ]
      },
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/search-tracker.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/verify-tracker.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/search-tracker.sh",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/build-gate.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/verify-guard.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/proof-guard.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/claim-guard.sh"
          }
        ]
      }
    ]
  }
}
